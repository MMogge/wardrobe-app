<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Wardrobe</title>
  <style>
    /* ───── Reset & Base ───── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f9f7f4;
      --surface: #ffffff;
      --surface2: #f2ede8;
      --border: #e5ddd5;
      --text: #1a1612;
      --text-muted: #7a6e65;
      --accent: #c4a882;
      --accent-dark: #9e7f5c;
      --accent-light: #f0e6d8;
      --danger: #d95f5f;
      --success: #5fa87a;
      --radius: 14px;
      --radius-sm: 8px;
      --shadow: 0 2px 12px rgba(0,0,0,0.07);
      --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
      --font: 'Inter', system-ui, -apple-system, sans-serif;
    }
    html { font-size: 16px; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.5;
    }
    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; border: none; outline: none; }
    input, textarea, select { font-family: inherit; outline: none; }
    img { display: block; max-width: 100%; }

    /* ───── Typography ───── */
    h1 { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.02em; }
    h2 { font-size: 1.15rem; font-weight: 600; }
    h3 { font-size: 0.95rem; font-weight: 600; }

    /* ───── Layout ───── */
    #app { display: flex; flex-direction: column; min-height: 100vh; }

    /* ───── Header ───── */
    header {
      position: sticky; top: 0; z-index: 100;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo { display: flex; align-items: center; gap: 10px; }
    .logo-icon {
      width: 34px; height: 34px;
      background: var(--accent);
      border-radius: 10px;
      display: grid; place-items: center;
      font-size: 1.1rem;
    }
    .logo-text { font-weight: 700; font-size: 1.1rem; letter-spacing: -0.01em; }
    .header-actions { display: flex; align-items: center; gap: 10px; }

    /* ───── Buttons ───── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 18px;
      border-radius: var(--radius-sm);
      font-size: 0.875rem; font-weight: 600;
      transition: all 0.15s;
    }
    .btn-primary {
      background: var(--accent);
      color: #fff;
    }
    .btn-primary:hover { background: var(--accent-dark); }
    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
    }
    .btn-ghost:hover { background: var(--surface2); color: var(--text); }
    .btn-icon {
      width: 38px; height: 38px; padding: 0;
      border-radius: var(--radius-sm);
      display: grid; place-items: center;
      font-size: 1.1rem;
    }
    .btn-danger {
      background: #fff0f0; color: var(--danger);
    }
    .btn-danger:hover { background: #ffd6d6; }
    .btn-sm { padding: 6px 12px; font-size: 0.8rem; }

    /* ───── Filter Bar ───── */
    .filter-bar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex; align-items: center; gap: 8px;
      height: 52px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-label { font-size: 0.75rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; margin-right: 4px; }
    .filter-chip {
      padding: 5px 14px;
      border-radius: 100px;
      border: 1.5px solid var(--border);
      background: transparent;
      font-size: 0.8rem; font-weight: 500;
      color: var(--text-muted);
      white-space: nowrap;
      transition: all 0.15s;
    }
    .filter-chip:hover { border-color: var(--accent); color: var(--accent-dark); }
    .filter-chip.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    .filter-sep { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; margin: 0 4px; }

    /* ───── Main Content ───── */
    main {
      flex: 1;
      padding: 28px 24px;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    /* ───── Stats Bar ───── */
    .stats {
      display: flex; align-items: center; gap: 20px;
      margin-bottom: 24px;
    }
    .stat-item { font-size: 0.85rem; color: var(--text-muted); }
    .stat-item strong { color: var(--text); font-weight: 600; }

    /* ───── Empty State ───── */
    .empty-state {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 80px 20px;
      text-align: center;
      gap: 16px;
    }
    .empty-icon {
      width: 80px; height: 80px;
      background: var(--accent-light);
      border-radius: 50%;
      display: grid; place-items: center;
      font-size: 2.2rem;
    }
    .empty-state h2 { color: var(--text); }
    .empty-state p { color: var(--text-muted); max-width: 300px; font-size: 0.9rem; }

    /* ───── Clothing Grid ───── */
    .clothing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
    }

    /* ───── Clothing Card ───── */
    .clothing-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      overflow: hidden;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    .clothing-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
      border-color: var(--accent);
    }
    .card-image {
      width: 100%; aspect-ratio: 3/4;
      object-fit: cover;
      background: var(--surface2);
    }
    .card-image-placeholder {
      width: 100%; aspect-ratio: 3/4;
      background: var(--surface2);
      display: grid; place-items: center;
      font-size: 2.5rem;
      color: var(--border);
    }
    .card-body { padding: 12px 14px 14px; }
    .card-name {
      font-weight: 600; font-size: 0.9rem;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      margin-bottom: 6px;
    }
    .card-tags { display: flex; flex-wrap: wrap; gap: 4px; }
    .tag {
      display: inline-flex; align-items: center; gap: 3px;
      padding: 3px 8px;
      border-radius: 100px;
      font-size: 0.7rem; font-weight: 500;
      background: var(--accent-light);
      color: var(--accent-dark);
    }
    .tag.season { background: #e8f4e8; color: #3d7a4d; }
    .tag.mood { background: #e8e8f4; color: #4d4d7a; }
    .tag.color { background: var(--surface2); color: var(--text-muted); }
    .card-analyzing {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 14px;
      font-size: 0.75rem; color: var(--text-muted);
      background: var(--accent-light);
    }
    .spinner {
      width: 14px; height: 14px;
      border: 2px solid var(--accent-light);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      flex-shrink: 0;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ───── Upload Drop Zone ───── */
    .upload-zone {
      border: 2px dashed var(--border);
      border-radius: var(--radius);
      padding: 40px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: var(--surface);
      margin-bottom: 28px;
    }
    .upload-zone:hover, .upload-zone.dragover {
      border-color: var(--accent);
      background: var(--accent-light);
    }
    .upload-zone-icon { font-size: 2rem; margin-bottom: 10px; }
    .upload-zone p { color: var(--text-muted); font-size: 0.875rem; }
    .upload-zone strong { color: var(--accent-dark); }

    /* ───── Modal Overlay ───── */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.45);
      backdrop-filter: blur(4px);
      display: grid; place-items: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      width: 100%; max-width: 760px;
      max-height: 90vh;
      overflow: hidden;
      display: flex; flex-direction: column;
      transform: translateY(12px);
      transition: transform 0.2s;
    }
    .modal-overlay.open .modal { transform: translateY(0); }

    .modal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 24px 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .modal-body {
      flex: 1; overflow-y: auto;
      padding: 24px;
    }
    .modal-footer {
      padding: 16px 24px;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      flex-shrink: 0;
    }

    /* ───── Detail Modal Layout ───── */
    .detail-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 28px;
    }
    @media (max-width: 600px) {
      .detail-layout { grid-template-columns: 1fr; }
    }
    .detail-image-wrap {
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
      aspect-ratio: 3/4;
      background: var(--surface2);
    }
    .detail-image-wrap img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .detail-fields { display: flex; flex-direction: column; gap: 18px; }
    .field-group { display: flex; flex-direction: column; gap: 6px; }
    .field-label {
      font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--text-muted);
    }
    .field-value {
      font-size: 0.9rem; color: var(--text);
      display: flex; flex-wrap: wrap; gap: 5px;
    }

    /* ───── Form Inputs ───── */
    .input {
      width: 100%; padding: 9px 12px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 0.9rem; color: var(--text);
      background: var(--surface);
      transition: border-color 0.15s;
    }
    .input:focus { border-color: var(--accent); }
    .input-name {
      font-size: 1.1rem; font-weight: 600;
      padding: 10px 0;
      border: none; border-bottom: 2px solid var(--border);
      border-radius: 0;
      background: transparent;
    }
    .input-name:focus { border-color: var(--accent); }

    /* ───── Tag Editor ───── */
    .tag-editor {
      display: flex; flex-wrap: wrap; gap: 5px;
      padding: 8px 10px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      min-height: 42px;
      cursor: text;
    }
    .tag-editor:focus-within { border-color: var(--accent); }
    .tag-editable {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 8px;
      border-radius: 100px;
      font-size: 0.78rem; font-weight: 500;
      background: var(--accent-light);
      color: var(--accent-dark);
    }
    .tag-editable .remove {
      cursor: pointer; opacity: 0.6; line-height: 1;
      font-size: 0.9rem;
    }
    .tag-editable .remove:hover { opacity: 1; }
    .tag-input {
      border: none; background: transparent;
      font-size: 0.78rem; min-width: 80px; flex: 1;
      color: var(--text);
    }
    .tag-input::placeholder { color: var(--text-muted); }

    /* ───── Settings Modal ───── */
    .settings-form { display: flex; flex-direction: column; gap: 20px; }
    .setting-item { display: flex; flex-direction: column; gap: 8px; }
    .setting-label { font-weight: 600; font-size: 0.875rem; }
    .setting-desc { font-size: 0.8rem; color: var(--text-muted); }
    .api-key-wrap { position: relative; }
    .api-key-wrap .input { padding-right: 40px; font-family: monospace; font-size: 0.82rem; }
    .api-key-toggle {
      position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer;
      color: var(--text-muted); font-size: 1rem;
      padding: 4px;
    }
    .api-key-toggle:hover { color: var(--text); }

    /* ───── Analyzing overlay on card ───── */
    .card-overlay {
      position: relative;
    }
    .card-overlay::after {
      content: '';
      position: absolute; inset: 0;
      background: rgba(255,255,255,0.6);
      border-radius: var(--radius);
    }

    /* ───── Color swatch ───── */
    .color-swatch {
      display: inline-block;
      width: 14px; height: 14px;
      border-radius: 3px;
      border: 1px solid rgba(0,0,0,0.1);
      flex-shrink: 0;
    }

    /* ───── Toast ───── */
    .toast-container {
      position: fixed; bottom: 24px; right: 24px; z-index: 999;
      display: flex; flex-direction: column; gap: 8px;
    }
    .toast {
      padding: 12px 18px;
      border-radius: var(--radius-sm);
      font-size: 0.875rem; font-weight: 500;
      box-shadow: var(--shadow-lg);
      animation: slideIn 0.2s ease;
      max-width: 320px;
    }
    .toast.success { background: var(--success); color: #fff; }
    .toast.error { background: var(--danger); color: #fff; }
    .toast.info { background: var(--accent); color: #fff; }
    @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    /* ───── No results ───── */
    .no-results {
      text-align: center; padding: 60px 20px;
      color: var(--text-muted);
    }
    .no-results .icon { font-size: 2.5rem; margin-bottom: 12px; }
    .no-results p { font-size: 0.9rem; }

    /* ───── Analyzing animation on detail view ───── */
    .analyzing-banner {
      background: var(--accent-light);
      border: 1px solid var(--accent);
      border-radius: var(--radius-sm);
      padding: 14px 18px;
      display: flex; align-items: center; gap: 12px;
      font-size: 0.875rem; color: var(--accent-dark);
    }
    .analyzing-banner .spinner {
      width: 18px; height: 18px;
      border-color: var(--accent-light);
      border-top-color: var(--accent-dark);
    }

    /* ───── Scrollbar ───── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

    /* ───── Responsive ───── */
    @media (max-width: 500px) {
      header { padding: 0 16px; }
      main { padding: 20px 16px; }
      .filter-bar { padding: 0 16px; }
      .clothing-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .modal-body { padding: 16px; }
    }
  </style>
</head>
<body>
<div id="app">

  <!-- HEADER -->
  <header>
    <div class="logo">
      <div class="logo-icon">👗</div>
      <span class="logo-text">My Wardrobe</span>
    </div>
    <div class="header-actions">
      <button class="btn btn-ghost btn-icon" id="settingsBtn" title="Einstellungen">⚙️</button>
      <button class="btn btn-primary" id="addBtn">
        <span>+</span> Kleidung hinzufügen
      </button>
    </div>
  </header>

  <!-- FILTER BAR -->
  <div class="filter-bar" id="filterBar">
    <span class="filter-label">Filter</span>
    <button class="filter-chip active" data-filter="all">Alle</button>
    <div class="filter-sep"></div>
    <span class="filter-label">Kategorie</span>
    <button class="filter-chip" data-filter="cat:Oberteil">Oberteil</button>
    <button class="filter-chip" data-filter="cat:Hose">Hose</button>
    <button class="filter-chip" data-filter="cat:Kleid">Kleid</button>
    <button class="filter-chip" data-filter="cat:Jacke">Jacke</button>
    <button class="filter-chip" data-filter="cat:Schuhe">Schuhe</button>
    <button class="filter-chip" data-filter="cat:Accessoire">Accessoire</button>
    <div class="filter-sep"></div>
    <span class="filter-label">Jahreszeit</span>
    <button class="filter-chip" data-filter="season:Frühling">🌸 Frühling</button>
    <button class="filter-chip" data-filter="season:Sommer">☀️ Sommer</button>
    <button class="filter-chip" data-filter="season:Herbst">🍂 Herbst</button>
    <button class="filter-chip" data-filter="season:Winter">❄️ Winter</button>
    <div class="filter-sep"></div>
    <span class="filter-label">Style</span>
    <button class="filter-chip" data-filter="mood:Casual">Casual</button>
    <button class="filter-chip" data-filter="mood:Elegant">Elegant</button>
    <button class="filter-chip" data-filter="mood:Sportlich">Sportlich</button>
    <button class="filter-chip" data-filter="mood:Minimal">Minimal</button>
    <button class="filter-chip" data-filter="mood:Boho">Boho</button>
    <button class="filter-chip" data-filter="mood:Business">Business</button>
    <button class="filter-chip" data-filter="mood:Streetwear">Streetwear</button>
  </div>

  <!-- MAIN -->
  <main>
    <div class="stats" id="stats"></div>
    <div id="wardrobeGrid"></div>
  </main>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- Hidden file input -->
  <input type="file" id="fileInput" accept="image/*" multiple style="display:none" />

</div>

<!-- ═══════════════════════════════════════════════
     DETAIL / EDIT MODAL
════════════════════════════════════════════════ -->
<div class="modal-overlay" id="detailModal">
  <div class="modal" style="max-width:820px">
    <div class="modal-header">
      <h2 id="detailModalTitle">Kleidungsstück</h2>
      <button class="btn btn-ghost btn-icon" id="detailModalClose">✕</button>
    </div>
    <div class="modal-body" id="detailModalBody"></div>
    <div class="modal-footer">
      <button class="btn btn-danger btn-sm" id="deleteBtn">🗑 Löschen</button>
      <div style="display:flex;gap:10px">
        <button class="btn btn-ghost" id="detailCancelBtn">Abbrechen</button>
        <button class="btn btn-primary" id="saveBtn">Speichern</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     SETTINGS MODAL
════════════════════════════════════════════════ -->
<div class="modal-overlay" id="settingsModal">
  <div class="modal" style="max-width:480px">
    <div class="modal-header">
      <h2>⚙️ Einstellungen</h2>
      <button class="btn btn-ghost btn-icon" id="settingsModalClose">✕</button>
    </div>
    <div class="modal-body">
      <div class="settings-form">
        <div class="setting-item">
          <label class="setting-label" for="apiKeyInput">Anthropic API-Key</label>
          <p class="setting-desc">Für die automatische KI-Analyse deiner Kleidungsbilder. Den Key erhältst du unter <a href="https://console.anthropic.com" target="_blank" style="color:var(--accent-dark)">console.anthropic.com</a>.</p>
          <div class="api-key-wrap">
            <input class="input" type="password" id="apiKeyInput" placeholder="sk-ant-..." />
            <button class="api-key-toggle" id="apiKeyToggle">👁</button>
          </div>
        </div>
        <div class="setting-item">
          <label class="setting-label">Daten verwalten</label>
          <p class="setting-desc">Alle Kleidungsdaten werden lokal in deinem Browser gespeichert.</p>
          <div style="display:flex;gap:8px;margin-top:4px">
            <button class="btn btn-ghost btn-sm" id="exportDataBtn">📦 Exportieren</button>
            <button class="btn btn-danger btn-sm" id="clearDataBtn">🗑 Alle löschen</button>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer" style="justify-content:flex-end">
      <button class="btn btn-primary" id="saveSettingsBtn">Speichern</button>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════
const DB_KEY = 'wardrobe_items_v2';
const SETTINGS_KEY = 'wardrobe_settings';

let state = {
  items: loadItems(),
  settings: loadSettings(),
  activeFilter: 'all',
  editingItem: null,
};

function loadItems() {
  try { return JSON.parse(localStorage.getItem(DB_KEY)) || []; }
  catch { return []; }
}
function saveItems() {
  localStorage.setItem(DB_KEY, JSON.stringify(state.items));
}
function loadSettings() {
  try { return JSON.parse(localStorage.getItem(SETTINGS_KEY)) || {}; }
  catch { return {}; }
}
function saveSettings() {
  localStorage.setItem(SETTINGS_KEY, JSON.stringify(state.settings));
}

// ═══════════════════════════════════════════════════════════
//  UTILITIES
// ═══════════════════════════════════════════════════════════
function uid() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2);
}

function showToast(msg, type = 'info', duration = 3000) {
  const t = document.getElementById('toastContainer');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  t.appendChild(el);
  setTimeout(() => el.remove(), duration);
}

function openModal(id) {
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
}

// ═══════════════════════════════════════════════════════════
//  CLAUDE API – KI-ANALYSE
// ═══════════════════════════════════════════════════════════
async function analyzeClothing(base64Image, mimeType) {
  const apiKey = state.settings.apiKey;
  if (!apiKey) {
    showToast('Bitte zuerst den API-Key in den Einstellungen eintragen.', 'error');
    return null;
  }

  const prompt = `Du bist ein Modeexperte. Analysiere dieses Kleidungsstück-Bild und gib mir eine detaillierte Einschätzung.
Antworte NUR mit einem validen JSON-Objekt (kein Markdown, keine Erklärungen) in folgendem Format:

{
  "name": "Kurzer, beschreibender Name des Kleidungsstücks (z.B. 'Weißes Leinenhemd', 'Schwarze Skinny Jeans')",
  "kategorie": "Einer von: Oberteil, Hose, Kleid, Rock, Jacke, Mantel, Pullover, Schuhe, Accessoire, Sonstiges",
  "farben": ["Hauptfarbe", "ggf. Akzentfarbe"],
  "sitz": "Einer von: Slim/Eng, Regular/Normal, Oversized/Weit",
  "laenge": "Einer von: Kurz, Normal, Lang (je nach Kleidungsstück)",
  "material": "Erkanntes oder wahrscheinliches Material (z.B. Baumwolle, Leder, Leinen, Wolle, Synthetik)",
  "textur": "Kurzbeschreibung der Textur (z.B. Glatt, Gestrickt, Denim, Strukturiert, Seidig)",
  "waerme": "Einer von: Sehr leicht (25°C+), Leicht (20-25°C), Mittel (10-20°C), Warm (0-10°C), Sehr warm (-10-0°C)",
  "jahreszeiten": ["passende Jahreszeiten aus: Frühling, Sommer, Herbst, Winter"],
  "styleMood": ["2-3 passende Begriffe aus: Casual, Elegant, Sportlich, Minimal, Boho, Business, Streetwear, Romantic, Rock, Vintage, Preppy, Festlich"],
  "notizen": "Kurze stilistische Notiz oder Tipp wie man es kombinieren kann (1-2 Sätze)"
}`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-calls': 'true',
      },
      body: JSON.stringify({
        model: 'claude-opus-4-6',
        max_tokens: 1024,
        messages: [{
          role: 'user',
          content: [{
            type: 'image',
            source: {
              type: 'base64',
              media_type: mimeType,
              data: base64Image,
            }
          }, {
            type: 'text',
            text: prompt
          }]
        }]
      })
    });

    if (!response.ok) {
      const err = await response.json().catch(() => ({}));
      const msg = err?.error?.message || `HTTP ${response.status}`;
      showToast(`API-Fehler: ${msg}`, 'error', 5000);
      return null;
    }

    const data = await response.json();
    const text = data.content[0].text.trim();
    // Strip possible markdown fences
    const jsonStr = text.replace(/^```json\s*/,'').replace(/^```\s*/,'').replace(/\s*```$/,'');
    return JSON.parse(jsonStr);

  } catch (err) {
    console.error('Analyse-Fehler:', err);
    showToast(`Analyse fehlgeschlagen: ${err.message}`, 'error', 5000);
    return null;
  }
}

// ═══════════════════════════════════════════════════════════
//  UPLOAD & ANALYSE
// ═══════════════════════════════════════════════════════════
async function handleFiles(files) {
  const apiKey = state.settings.apiKey;
  if (!apiKey) {
    openModal('settingsModal');
    showToast('Bitte zuerst den API-Key hinterlegen.', 'info');
    return;
  }

  for (const file of Array.from(files)) {
    if (!file.type.startsWith('image/')) continue;

    const reader = new FileReader();
    const base64Promise = new Promise(res => {
      reader.onload = e => {
        const full = e.target.result;
        const b64 = full.split(',')[1];
        res({ b64, mimeType: file.type });
      };
      reader.readAsDataURL(file);
    });

    const { b64, mimeType } = await base64Promise;

    const item = {
      id: uid(),
      imageData: `data:${mimeType};base64,${b64}`,
      analyzing: true,
      name: file.name.replace(/\.[^.]+$/, '') || 'Neues Kleidungsstück',
      kategorie: '',
      farben: [],
      sitz: '',
      laenge: '',
      material: '',
      textur: '',
      waerme: '',
      jahreszeiten: [],
      styleMood: [],
      notizen: '',
      addedAt: new Date().toISOString(),
    };

    state.items.unshift(item);
    saveItems();
    renderGrid();

    // Analyse
    const result = await analyzeClothing(b64, mimeType);

    const idx = state.items.findIndex(i => i.id === item.id);
    if (idx !== -1) {
      state.items[idx] = {
        ...state.items[idx],
        analyzing: false,
        ...(result || { name: item.name }),
      };
      if (result) {
        showToast(`✓ ${result.name} analysiert!`, 'success');
      }
      saveItems();
      renderGrid();
    }
  }
}

// ═══════════════════════════════════════════════════════════
//  FILTER LOGIC
// ═══════════════════════════════════════════════════════════
function getFilteredItems() {
  const f = state.activeFilter;
  if (f === 'all') return state.items;
  if (f.startsWith('cat:')) {
    const cat = f.slice(4);
    return state.items.filter(i => i.kategorie === cat);
  }
  if (f.startsWith('season:')) {
    const s = f.slice(7);
    return state.items.filter(i => (i.jahreszeiten || []).includes(s));
  }
  if (f.startsWith('mood:')) {
    const m = f.slice(5);
    return state.items.filter(i => (i.styleMood || []).includes(m));
  }
  return state.items;
}

// ═══════════════════════════════════════════════════════════
//  RENDER
// ═══════════════════════════════════════════════════════════
function renderGrid() {
  const grid = document.getElementById('wardrobeGrid');
  const stats = document.getElementById('stats');
  const filtered = getFilteredItems();

  // Stats
  stats.innerHTML = `
    <span class="stat-item"><strong>${state.items.length}</strong> Teile gesamt</span>
    ${state.activeFilter !== 'all' ? `<span class="stat-item"><strong>${filtered.length}</strong> angezeigt</span>` : ''}
  `;

  if (state.items.length === 0) {
    grid.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">👗</div>
        <h2>Dein Kleiderschrank ist leer</h2>
        <p>Füge dein erstes Kleidungsstück hinzu – lade einfach ein Foto hoch und die KI analysiert es automatisch.</p>
        <button class="btn btn-primary" onclick="document.getElementById('fileInput').click()">Erstes Foto hochladen</button>
      </div>
    `;
    return;
  }

  if (filtered.length === 0) {
    grid.innerHTML = `
      <div class="no-results">
        <div class="icon">🔍</div>
        <p>Keine Kleidungsstücke für diesen Filter gefunden.</p>
      </div>
    `;
    return;
  }

  grid.innerHTML = '';
  const frag = document.createDocumentFragment();

  // Upload zone inside grid (as first card) when items exist
  const uploadCard = document.createElement('div');
  uploadCard.innerHTML = `
    <div class="upload-zone" id="uploadZoneGrid" style="aspect-ratio:3/4;display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0;padding:20px">
      <div class="upload-zone-icon">📷</div>
      <p style="font-size:0.8rem"><strong>Klick</strong> oder ziehen</p>
    </div>
  `;
  frag.appendChild(uploadCard);

  for (const item of filtered) {
    const card = document.createElement('div');
    card.className = 'clothing-card';
    card.dataset.id = item.id;

    const imgHtml = item.imageData
      ? `<img class="card-image" src="${item.imageData}" alt="${item.name}" loading="lazy" />`
      : `<div class="card-image-placeholder">👕</div>`;

    const tags = [];
    if (item.farben && item.farben.length) {
      tags.push(`<span class="tag color">${item.farben[0]}</span>`);
    }
    if (item.jahreszeiten && item.jahreszeiten.length) {
      tags.push(`<span class="tag season">${item.jahreszeiten[0]}</span>`);
    }
    if (item.styleMood && item.styleMood.length) {
      tags.push(`<span class="tag mood">${item.styleMood[0]}</span>`);
    }
    if (item.sitz) tags.push(`<span class="tag">${item.sitz}</span>`);

    card.innerHTML = `
      ${imgHtml}
      ${item.analyzing ? `<div class="card-analyzing"><div class="spinner"></div> KI analysiert...</div>` : ''}
      <div class="card-body">
        <div class="card-name">${item.name || 'Kein Name'}</div>
        <div class="card-tags">${tags.slice(0,3).join('')}</div>
      </div>
    `;

    card.addEventListener('click', () => openDetailModal(item.id));
    frag.appendChild(card);
  }

  grid.appendChild(frag);

  // Upload zone events
  const uz = document.getElementById('uploadZoneGrid');
  if (uz) {
    uz.addEventListener('click', () => document.getElementById('fileInput').click());
    uz.addEventListener('dragover', e => { e.preventDefault(); uz.classList.add('dragover'); });
    uz.addEventListener('dragleave', () => uz.classList.remove('dragover'));
    uz.addEventListener('drop', e => {
      e.preventDefault(); uz.classList.remove('dragover');
      handleFiles(e.dataTransfer.files);
    });
  }
}

// ═══════════════════════════════════════════════════════════
//  DETAIL MODAL
// ═══════════════════════════════════════════════════════════
function openDetailModal(id) {
  const item = state.items.find(i => i.id === id);
  if (!item) return;
  state.editingItem = { ...item };

  document.getElementById('detailModalTitle').textContent = item.name || 'Kleidungsstück';
  renderDetailModal(item);
  openModal('detailModal');
}

function renderDetailModal(item) {
  const body = document.getElementById('detailModalBody');

  const seasons = ['Frühling', 'Sommer', 'Herbst', 'Winter'];
  const moods = ['Casual', 'Elegant', 'Sportlich', 'Minimal', 'Boho', 'Business', 'Streetwear', 'Romantic', 'Rock', 'Vintage', 'Preppy', 'Festlich'];
  const cats = ['Oberteil', 'Hose', 'Kleid', 'Rock', 'Jacke', 'Mantel', 'Pullover', 'Schuhe', 'Accessoire', 'Sonstiges'];
  const sitze = ['Slim/Eng', 'Regular/Normal', 'Oversized/Weit'];
  const waerme = ['Sehr leicht (25°C+)', 'Leicht (20-25°C)', 'Mittel (10-20°C)', 'Warm (0-10°C)', 'Sehr warm (-10-0°C)'];

  body.innerHTML = `
    ${item.analyzing ? `<div class="analyzing-banner" style="margin-bottom:20px"><div class="spinner"></div> KI analysiert gerade das Bild – Felder werden gleich automatisch ausgefüllt…</div>` : ''}
    <div class="detail-layout">
      <div>
        <div class="detail-image-wrap">
          ${item.imageData ? `<img src="${item.imageData}" alt="${item.name}" />` : '<div style="height:100%;display:grid;place-items:center;font-size:3rem">👕</div>'}
        </div>
      </div>
      <div class="detail-fields">

        <div class="field-group">
          <label class="field-label">Name</label>
          <input class="input input-name" id="f_name" type="text" value="${esc(item.name || '')}" placeholder="z.B. Weißes Leinenhemd" />
        </div>

        <div class="field-group">
          <label class="field-label">Kategorie</label>
          <select class="input" id="f_kat">
            <option value="">– wählen –</option>
            ${cats.map(c => `<option value="${c}" ${item.kategorie===c?'selected':''}>${c}</option>`).join('')}
          </select>
        </div>

        <div class="field-group">
          <label class="field-label">Farben</label>
          ${buildTagEditor('f_farben', item.farben || [], 'Farbe eingeben, Enter drücken')}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div class="field-group">
            <label class="field-label">Sitz</label>
            <select class="input" id="f_sitz">
              <option value="">– wählen –</option>
              ${sitze.map(s => `<option value="${s}" ${item.sitz===s?'selected':''}>${s}</option>`).join('')}
            </select>
          </div>
          <div class="field-group">
            <label class="field-label">Länge</label>
            <select class="input" id="f_laenge">
              <option value="">– wählen –</option>
              ${['Kurz','Normal','Lang'].map(l => `<option value="${l}" ${item.laenge===l?'selected':''}>${l}</option>`).join('')}
            </select>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div class="field-group">
            <label class="field-label">Material</label>
            <input class="input" id="f_material" type="text" value="${esc(item.material||'')}" placeholder="z.B. Baumwolle" />
          </div>
          <div class="field-group">
            <label class="field-label">Textur</label>
            <input class="input" id="f_textur" type="text" value="${esc(item.textur||'')}" placeholder="z.B. Glatt, Denim" />
          </div>
        </div>

        <div class="field-group">
          <label class="field-label">Wärme / Temperatur</label>
          <select class="input" id="f_waerme">
            <option value="">– wählen –</option>
            ${waerme.map(w => `<option value="${w}" ${item.waerme===w?'selected':''}>${w}</option>`).join('')}
          </select>
        </div>

        <div class="field-group">
          <label class="field-label">Jahreszeiten</label>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            ${seasons.map(s => `
              <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-size:0.85rem">
                <input type="checkbox" data-group="jahreszeiten" value="${s}" ${(item.jahreszeiten||[]).includes(s)?'checked':''} style="accent-color:var(--accent)" />
                ${s}
              </label>
            `).join('')}
          </div>
        </div>

        <div class="field-group">
          <label class="field-label">Style-Mood</label>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            ${moods.map(m => `
              <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-size:0.85rem">
                <input type="checkbox" data-group="styleMood" value="${m}" ${(item.styleMood||[]).includes(m)?'checked':''} style="accent-color:var(--accent)" />
                ${m}
              </label>
            `).join('')}
          </div>
        </div>

        <div class="field-group">
          <label class="field-label">Notizen</label>
          <textarea class="input" id="f_notizen" rows="3" placeholder="Kombinationstipps, Besonderheiten…">${esc(item.notizen||'')}</textarea>
        </div>

      </div>
    </div>
  `;

  // Tag editors
  initTagEditor('f_farben');
}

function buildTagEditor(id, values, placeholder) {
  const tags = values.map(v => `
    <span class="tag-editable">
      ${esc(v)}
      <span class="remove" data-value="${esc(v)}">×</span>
    </span>
  `).join('');
  return `
    <div class="tag-editor" id="${id}">
      ${tags}
      <input class="tag-input" placeholder="${placeholder}" />
    </div>
  `;
}

function initTagEditor(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const input = el.querySelector('.tag-input');

  el.addEventListener('click', e => {
    if (e.target.classList.contains('remove')) {
      e.target.closest('.tag-editable').remove();
    } else {
      input.focus();
    }
  });

  input.addEventListener('keydown', e => {
    if ((e.key === 'Enter' || e.key === ',') && input.value.trim()) {
      e.preventDefault();
      addTag(el, input.value.trim());
      input.value = '';
    }
    if (e.key === 'Backspace' && !input.value) {
      const tags = el.querySelectorAll('.tag-editable');
      if (tags.length) tags[tags.length-1].remove();
    }
  });
}

function addTag(container, value) {
  const span = document.createElement('span');
  span.className = 'tag-editable';
  span.innerHTML = `${esc(value)}<span class="remove" data-value="${esc(value)}">×</span>`;
  container.insertBefore(span, container.querySelector('.tag-input'));
}

function getTagEditorValues(id) {
  const el = document.getElementById(id);
  if (!el) return [];
  return Array.from(el.querySelectorAll('.tag-editable')).map(t => t.textContent.replace('×','').trim());
}

function getCheckboxValues(group) {
  return Array.from(document.querySelectorAll(`[data-group="${group}"]:checked`)).map(c => c.value);
}

function esc(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function collectFormValues() {
  return {
    name: document.getElementById('f_name')?.value.trim() || '',
    kategorie: document.getElementById('f_kat')?.value || '',
    farben: getTagEditorValues('f_farben'),
    sitz: document.getElementById('f_sitz')?.value || '',
    laenge: document.getElementById('f_laenge')?.value || '',
    material: document.getElementById('f_material')?.value.trim() || '',
    textur: document.getElementById('f_textur')?.value.trim() || '',
    waerme: document.getElementById('f_waerme')?.value || '',
    jahreszeiten: getCheckboxValues('jahreszeiten'),
    styleMood: getCheckboxValues('styleMood'),
    notizen: document.getElementById('f_notizen')?.value.trim() || '',
  };
}

// ═══════════════════════════════════════════════════════════
//  EVENT LISTENERS
// ═══════════════════════════════════════════════════════════
// Add button
document.getElementById('addBtn').addEventListener('click', () => {
  document.getElementById('fileInput').click();
});

// File input
document.getElementById('fileInput').addEventListener('change', e => {
  handleFiles(e.target.files);
  e.target.value = '';
});

// Drag & drop on full page
document.addEventListener('dragover', e => e.preventDefault());
document.addEventListener('drop', e => {
  e.preventDefault();
  if (e.dataTransfer.files.length) handleFiles(e.dataTransfer.files);
});

// Filter chips
document.getElementById('filterBar').addEventListener('click', e => {
  const chip = e.target.closest('.filter-chip');
  if (!chip) return;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  chip.classList.add('active');
  state.activeFilter = chip.dataset.filter;
  renderGrid();
});

// Detail modal close
document.getElementById('detailModalClose').addEventListener('click', () => closeModal('detailModal'));
document.getElementById('detailCancelBtn').addEventListener('click', () => closeModal('detailModal'));

// Save button
document.getElementById('saveBtn').addEventListener('click', () => {
  if (!state.editingItem) return;
  const values = collectFormValues();
  const idx = state.items.findIndex(i => i.id === state.editingItem.id);
  if (idx !== -1) {
    state.items[idx] = { ...state.items[idx], ...values };
    saveItems();
    renderGrid();
    showToast('Gespeichert!', 'success');
  }
  closeModal('detailModal');
});

// Delete button
document.getElementById('deleteBtn').addEventListener('click', () => {
  if (!state.editingItem) return;
  if (confirm(`"${state.editingItem.name}" wirklich löschen?`)) {
    state.items = state.items.filter(i => i.id !== state.editingItem.id);
    saveItems();
    renderGrid();
    showToast('Gelöscht.', 'info');
    closeModal('detailModal');
  }
});

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) {
      closeModal(overlay.id);
    }
  });
});

// Settings
document.getElementById('settingsBtn').addEventListener('click', () => {
  document.getElementById('apiKeyInput').value = state.settings.apiKey || '';
  openModal('settingsModal');
});
document.getElementById('settingsModalClose').addEventListener('click', () => closeModal('settingsModal'));
document.getElementById('saveSettingsBtn').addEventListener('click', () => {
  state.settings.apiKey = document.getElementById('apiKeyInput').value.trim();
  saveSettings();
  showToast('Einstellungen gespeichert!', 'success');
  closeModal('settingsModal');
});

// API key show/hide
document.getElementById('apiKeyToggle').addEventListener('click', () => {
  const input = document.getElementById('apiKeyInput');
  const btn = document.getElementById('apiKeyToggle');
  if (input.type === 'password') {
    input.type = 'text'; btn.textContent = '🙈';
  } else {
    input.type = 'password'; btn.textContent = '👁';
  }
});

// Export data
document.getElementById('exportDataBtn').addEventListener('click', () => {
  const blob = new Blob([JSON.stringify(state.items, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'wardrobe-export.json'; a.click();
  URL.revokeObjectURL(url);
  showToast('Exportiert!', 'success');
});

// Clear data
document.getElementById('clearDataBtn').addEventListener('click', () => {
  if (confirm('Wirklich ALLE Kleidungsdaten löschen? Das kann nicht rückgängig gemacht werden.')) {
    state.items = [];
    saveItems();
    renderGrid();
    showToast('Alle Daten gelöscht.', 'info');
    closeModal('settingsModal');
  }
});

// Keyboard: ESC closes modals
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-overlay.open').forEach(m => closeModal(m.id));
  }
});

// ═══════════════════════════════════════════════════════════
//  INITIAL RENDER
// ═══════════════════════════════════════════════════════════
function init() {
  renderGrid();
  // Show settings hint if no API key
  if (!state.settings.apiKey) {
    setTimeout(() => showToast('👋 Bitte zuerst den API-Key in ⚙️ Einstellungen eintragen.', 'info', 6000), 800);
  }
}

init();
</script>
